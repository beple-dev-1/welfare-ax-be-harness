{
  "cleanupPeriodDays": 90,
  "env": {
    "CLAUDE_CODE_FORK_SUBAGENT": "0"
  },
  "permissions": {
    "allow": [
      "mcp__postgres__query",
      "mcp__context7__resolve-library-id",
      "mcp__context7__get-library-docs",
      "mcp__gitlab__*",
      "mcp__playwright__*",
      "Edit(target/plans/**)",
      "Edit(target/works/**)",
      "Edit(target/test-reports/**)",
      "Bash(wc:*)",
      "Bash(grep:*)",
      "Bash(ls:*)",
      "Bash(git:*)",
      "Bash(git push:*)",
      "Bash(node:*)",
      "Bash(command:*)",
      "Bash(cat:*)",
      "Bash(semgrep:*)",
      "Bash(./gradlew:*)",
      "Bash(gradlew.bat:*)",
      "Bash(pkill:*)",
      "Bash(TEMPFILE=*)",
      "Bash(REVIEW_BODY=*)",
      "Bash(RESULT=*)",
      "Bash(JSON_PAYLOAD=*)",
      "Bash(GITLAB_URL=*)",
      "Bash(ACCESS_TOKEN=*)",
      "Bash(PROJECT_ID=*)",
      "Bash(MR_IID=*)",
      "Bash(API_URL=*)",
      "Bash(RESPONSE=*)",
      "Bash(HTTP_*)",
      "Bash(mkdir:*)",
      "Write(target/**)"
    ],
    "deny": [
      "Bash(git push --force:*)",
      "Bash(git push --force-with-lease:*)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean -fd:*)",
      "Bash(git clean -f:*)",
      "Bash(git branch -D:*)",
      "Bash(git checkout -- :*)",
      "Bash(git restore --source:*)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Edit(**/.env)",
      "Edit(**/.env.*)",
      "Write(**/.env)",
      "Write(**/.env.*)",
      "Read(**/credentials.json)",
      "Edit(**/credentials.json)",
      "Write(**/credentials.json)",
      "Read(**/*.pem)",
      "Read(**/*.p12)",
      "Read(**/*.jks)",
      "Read(**/id_rsa)",
      "Read(**/id_rsa.pub)",
      "Edit(**/*.pem)",
      "Edit(**/*.p12)",
      "Edit(**/*.jks)",
      "Edit(**/id_rsa)",
      "Write(**/*.pem)",
      "Write(**/*.p12)",
      "Write(**/*.jks)",
      "Write(**/id_rsa)",
      "Read(**/src/main/resources/application-prod*)",
      "Read(**/src/main/resources/application-production*)",
      "Edit(**/src/main/resources/application-prod*)",
      "Edit(**/src/main/resources/application-production*)",
      "Write(**/src/main/resources/application-prod*)",
      "Write(**/src/main/resources/application-production*)"
    ]
  },
  "enableAllProjectMcpServers": true,
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "mcp__postgres__query",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/check-postgres-query.sh\"",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Read|Write|Edit|Bash|PowerShell|shell_command|functions\\.shell_command",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/check-file-access.sh\"",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/statusline.sh\"",
    "padding": 1
  }
}
